{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch built-in server and debug",
            "type": "php",
            "request": "launch",
            "runtimeArgs": [
                "-dxdebug.mode=debug",
                "-dxdebug.start_with_request=yes",
                "-dxdebug.client_host=127.0.0.1",
                "-dxdebug.client_port=9003",
                "-S",
                "localhost:8000",
                "-t",
                "public",
                "public/index.php"
            ],
            "port": 9003,
            "cwd": "${workspaceFolder}",
            "serverReadyAction": {
                "action": "openExternally"
            }
        }
    ]
}